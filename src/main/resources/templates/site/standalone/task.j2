<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ pageTitle }} - Data Catalog</title>
  <link rel="stylesheet" href="{{ basePath }}style.css">
  {% if lineageJson or aclJson or relationsJson %}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@xyflow/react@12.6.0/dist/style.min.css">
  <script type="importmap">
  {
    "imports": {
      "react": "https://esm.sh/react@18.3.1",
      "react/": "https://esm.sh/react@18.3.1/",
      "react-dom": "https://esm.sh/react-dom@18.3.1?external=react",
      "react-dom/client": "https://esm.sh/react-dom@18.3.1/client?external=react",
      "@xyflow/react": "https://esm.sh/@xyflow/react@12.6.0?external=react,react-dom",
      "dagre": "https://esm.sh/dagre@0.8.5"
    }
  }
  </script>
  {% endif %}
</head>
<body>
  <nav class="sidebar">
    <div class="sidebar-header">
      <a href="{{ basePath }}index.html"><h2>Data Catalog</h2></a>
    </div>
    {% if domains %}
    <div class="nav-section">
      <div class="nav-section-title">Load</div>
      <ul class="nav-list">
        {% for d in domains %}
        <li>
          <details>
            <summary>{{ d.name }}</summary>
            <ul>
              {% for t in d.tables %}
              <li><a href="{{ basePath }}load/{{ d.normalizedName }}/{{ t.name }}.html">{{ t.name }}</a></li>
              {% endfor %}
            </ul>
          </details>
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
    {% if jobs %}
    <div class="nav-section">
      <div class="nav-section-title">Transform</div>
      <ul class="nav-list">
        {% for j in jobs %}
        <li>
          <details{% if j.name == job.name %} open{% endif %}>
            <summary>{{ j.name }}</summary>
            <ul>
              {% for t in j.tasks %}
              <li><a href="{{ basePath }}transform/{{ j.normalizedName }}/{{ t.name }}.html"{% if t.name == task.name and j.name == job.name %} style="color:var(--primary);font-weight:600"{% endif %}>{{ t.name }}</a></li>
              {% endfor %}
            </ul>
          </details>
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </nav>

  <main class="content">
    <div class="breadcrumb">
      <a href="{{ basePath }}index.html">Home</a> &rsaquo;
      <span>Transform</span> &rsaquo;
      <span>{{ job.name }}</span> &rsaquo;
      <span>{{ task.name }}</span>
    </div>

    <h1>{{ task.tableName }}</h1>
    <p class="description">{{ task.comment }}</p>

    <div class="tab-group">
      <div class="tab-bar">
        <button class="tab-btn active" data-tab="general">General</button>
        {% if sql %}<button class="tab-btn" data-tab="sql">SQL</button>{% endif %}
        {% if python %}<button class="tab-btn" data-tab="python">Python</button>{% endif %}
        {% if task.attributes %}<button class="tab-btn" data-tab="attributes">Attributes</button>{% endif %}
        {% if task.expectations %}<button class="tab-btn" data-tab="expectations">Expectations</button>{% endif %}
        {% if lineageJson %}<button class="tab-btn" data-tab="lineage">Lineage</button>{% endif %}
        <button class="tab-btn" data-tab="relations">Relations</button>
        {% if aclJson %}<button class="tab-btn" data-tab="acl">Access Control</button>{% endif %}
      </div>

      <div id="general" class="tab-pane active">
        <table class="data-table props-table">
          <tbody>
            <tr><th>Name</th><td>{{ task.name }}</td></tr>
            <tr>
              <th>Tags</th>
              <td>
                {% for tag in task.tags %}<span class="tag">{{ tag }}</span>{% endfor %}
                {% if not task.tags %}<span class="empty">None</span>{% endif %}
              </td>
            </tr>
            {% if task.writeStrategy %}
            <tr>
              <th>Write Strategy</th>
              <td>
                <ul class="strategy-list">
                  {% if task.writeStrategy.type %}<li><strong>type:</strong> {{ task.writeStrategy.type }}</li>{% endif %}
                  {% if task.writeStrategy.key %}<li><strong>key:</strong> {{ task.writeStrategy.key }}</li>{% endif %}
                  {% if task.writeStrategy.timestamp %}<li><strong>timestamp:</strong> {{ task.writeStrategy.timestamp }}</li>{% endif %}
                  {% if task.writeStrategy.queryFilter %}<li><strong>queryFilter:</strong> {{ task.writeStrategy.queryFilter }}</li>{% endif %}
                  {% if task.writeStrategy.on %}<li><strong>on:</strong> {{ task.writeStrategy.on }}</li>{% endif %}
                  {% if task.writeStrategy.startTs %}<li><strong>startTs:</strong> {{ task.writeStrategy.startTs }}</li>{% endif %}
                  {% if task.writeStrategy.endTs %}<li><strong>endTs:</strong> {{ task.writeStrategy.endTs }}</li>{% endif %}
                </ul>
              </td>
            </tr>
            {% endif %}
          </tbody>
        </table>
      </div>

      {% if sql %}
      <div id="sql" class="tab-pane">
        <pre class="code-block"><code class="lang-sql">{{ sql }}</code></pre>
      </div>
      {% endif %}

      {% if python %}
      <div id="python" class="tab-pane">
        <pre class="code-block"><code class="lang-python">{{ python }}</code></pre>
      </div>
      {% endif %}

      {% if task.attributes %}
      <div id="attributes" class="tab-pane">
        <div style="overflow-x:auto">
          <table class="data-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Description</th>
                <th>Required</th>
                <th>Tags</th>
              </tr>
            </thead>
            <tbody>
              {% for attr in task.attributes %}
              <tr>
                <td><strong>{{ attr.name }}</strong></td>
                <td><code>{{ attr.type }}</code></td>
                <td>{{ attr.comment }}</td>
                <td>{{ attr.required }}</td>
                <td>{% for tag in attr.tags %}<span class="tag">{{ tag }}</span>{% endfor %}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
      {% endif %}

      {% if task.expectations %}
      <div id="expectations" class="tab-pane">
        <div style="overflow-x:auto">
          <table class="data-table">
            <thead>
              <tr>
                <th>Expectation</th>
                <th>Fail on Error</th>
              </tr>
            </thead>
            <tbody>
              {% for exp in task.expectations %}
              <tr>
                <td><code>{{ exp.query }}</code></td>
                <td>{{ exp.failOnError }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
      {% endif %}

      {% if lineageJson %}
      <div id="lineage" class="tab-pane">
        <div id="lineage-root"></div>
      </div>
      <script id="lineage-data" type="application/json">{{ lineageJson }}</script>
      {% endif %}

      <div id="relations" class="tab-pane">
        {% if relationsJson %}
        <div id="relations-root"></div>
        <script id="relations-data" type="application/json">{{ relationsJson }}</script>
        {% else %}
        <p class="empty">No relations data available.</p>
        {% endif %}
      </div>

      {% if aclJson %}
      <div id="acl" class="tab-pane">
        <div id="acl-root"></div>
      </div>
      <script id="acl-data" type="application/json">{{ aclJson }}</script>
      {% endif %}
    </div>
  </main>

  <script>
  document.querySelectorAll('.tab-btn').forEach(function(btn){
    btn.addEventListener('click',function(){
      var group=this.closest('.tab-group');
      group.querySelectorAll('.tab-btn').forEach(function(b){b.classList.remove('active')});
      group.querySelectorAll('.tab-pane').forEach(function(p){p.classList.remove('active')});
      this.classList.add('active');
      group.querySelector('#'+this.dataset.tab).classList.add('active');
      try{localStorage.setItem('sl-active-tab',this.dataset.tab)}catch(e){}
    });
  });
  /* Restore last active tab */
  try{
    var saved=localStorage.getItem('sl-active-tab');
    if(saved){var btn=document.querySelector('.tab-btn[data-tab="'+saved+'"]');if(btn)btn.click();}
  }catch(e){}

  /* SQL syntax highlighting */
  document.querySelectorAll('code.lang-sql').forEach(function(el){
    var keywords = 'SELECT|FROM|WHERE|AND|OR|NOT|IN|ON|AS|JOIN|LEFT|RIGHT|INNER|OUTER|FULL|CROSS|GROUP\\s+BY|ORDER\\s+BY|HAVING|LIMIT|OFFSET|UNION|ALL|INSERT|INTO|VALUES|UPDATE|SET|DELETE|CREATE|ALTER|DROP|TABLE|INDEX|VIEW|WITH|DISTINCT|CASE|WHEN|THEN|ELSE|END|IS|NULL|LIKE|BETWEEN|EXISTS|OVER|PARTITION\\s+BY|WINDOW|CURRENT_TIMESTAMP|TRUE|FALSE|ASC|DESC|SUM|COUNT|AVG|MIN|MAX|COALESCE|CAST|SUBSTRING|TRIM|UPPER|LOWER|REPLACE|CONCAT|LENGTH|CURRENT_DATE|CURRENT_TIME|EXTRACT|YEAR|MONTH|DAY|HOUR|MINUTE|SECOND|INTERVAL|ANY|SOME|FETCH|NEXT|ROWS|ONLY|RECURSIVE|LATERAL|TABLESAMPLE|UNNEST|PIVOT|UNPIVOT|QUALIFY|EXCEPT|INTERSECT|ROLLUP|CUBE|GROUPING|SETS|FILTER|WITHIN|MERGE|MATCHED|USING|IF|ISNULL|IFNULL';
    var html = el.textContent
      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/(--[^\n]*)/g,'<span class="hl-comment">$1</span>')
      .replace(/('(?:[^'\\]|\\.)*')/g,'<span class="hl-string">$1</span>')
      .replace(new RegExp('\\b('+keywords+')\\b','gi'), function(m){return '<span class="hl-keyword">'+m+'</span>';})
      .replace(/\b(\d+(?:\.\d+)?)\b/g,'<span class="hl-number">$1</span>');
    el.innerHTML = html;
  });

  /* Python syntax highlighting */
  document.querySelectorAll('code.lang-python').forEach(function(el){
    var keywords = 'def|class|if|elif|else|for|while|return|import|from|as|try|except|finally|with|raise|pass|break|continue|and|or|not|in|is|lambda|yield|global|nonlocal|assert|del|True|False|None|async|await|print';
    var html = el.textContent
      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/(#[^\n]*)/g,'<span class="hl-comment">$1</span>')
      .replace(/("""[\s\S]*?"""|'''[\s\S]*?''')/g,'<span class="hl-string">$1</span>')
      .replace(/("(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*')/g,'<span class="hl-string">$1</span>')
      .replace(new RegExp('\\b('+keywords+')\\b','g'), function(m){return '<span class="hl-keyword">'+m+'</span>';})
      .replace(/\b(\d+(?:\.\d+)?)\b/g,'<span class="hl-number">$1</span>')
      .replace(/@(\w+)/g,'<span class="hl-decorator">@$1</span>');
    el.innerHTML = html;
  });

  /* Add line numbers to code blocks */
  document.querySelectorAll('pre.code-block code').forEach(function(code){
    var lines = code.innerHTML.split('\n');
    if (lines[lines.length-1] === '') lines.pop();
    var nums = lines.map(function(_,i){ return i+1; }).join('\n');
    var gutter = document.createElement('div');
    gutter.className = 'line-numbers';
    gutter.textContent = nums;
    code.parentElement.insertBefore(gutter, code);
  });
  </script>

  {% if lineageJson or aclJson or relationsJson %}
  <script type="module">
  import { mountFlow } from '{{ basePath }}flow.js';
  function lazyMount(tabName, rootId, dataId, format) {
    var data = JSON.parse(document.getElementById(dataId).textContent);
    var root = document.getElementById(rootId);
    var mounted = false;
    function doMount() { if (!mounted) { mounted = true; setTimeout(function() { mountFlow(root, data, format, 'LR'); }, 0); } }
    document.querySelector('[data-tab="'+tabName+'"]').addEventListener('click', doMount);
    if (document.querySelector('.tab-btn[data-tab="'+tabName+'"]').classList.contains('active')) doMount();
  }
  {% if lineageJson %}lazyMount('lineage', 'lineage-root', 'lineage-data', 'lineage');{% endif %}
  {% if aclJson %}lazyMount('acl', 'acl-root', 'acl-data', 'table-deps');{% endif %}
  {% if relationsJson %}lazyMount('relations', 'relations-root', 'relations-data', 'table-deps');{% endif %}
  </script>
  {% endif %}
</body>
</html>
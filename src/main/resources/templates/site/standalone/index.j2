<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Data Catalog</title>
  <link rel="stylesheet" href="{{ basePath }}style.css">
</head>
<body>
  <nav class="sidebar">
    <div class="sidebar-header">
      <a href="{{ basePath }}index.html"><h2>Data Catalog</h2></a>
    </div>
    {% if domains %}
    <div class="nav-section">
      <div class="nav-section-title">Load</div>
      <ul class="nav-list">
        {% for domain in domains %}
        <li>
          <details>
            <summary>{{ domain.name }}</summary>
            <ul>
              {% for table in domain.tables %}
              <li><a href="{{ basePath }}load/{{ domain.normalizedName }}/{{ table.name }}.html">{{ table.name }}</a></li>
              {% endfor %}
            </ul>
          </details>
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
    {% if jobs %}
    <div class="nav-section">
      <div class="nav-section-title">Transform</div>
      <ul class="nav-list">
        {% for job in jobs %}
        <li>
          <details>
            <summary>{{ job.name }}</summary>
            <ul>
              {% for task in job.tasks %}
              <li><a href="{{ basePath }}transform/{{ job.normalizedName }}/{{ task.name }}.html">{{ task.name }}</a></li>
              {% endfor %}
            </ul>
          </details>
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </nav>

  <main class="content">
    <h1>Data Catalog</h1>
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-value">{{ domains | length }}</div>
        <div class="stat-label">Domains</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">{{ totalTables }}</div>
        <div class="stat-label">Tables</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">{{ jobs | length }}</div>
        <div class="stat-label">Jobs</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">{{ totalTasks }}</div>
        <div class="stat-label">Tasks</div>
      </div>
    </div>

    {% if domains %}
    <div class="section">
      <h2>Load</h2>
      <div class="item-grid">
        {% for domain in domains %}
        <div class="item-card">
          <h3>{{ domain.name }}</h3>
          <p>{{ domain.comment }}</p>
          <div style="margin-top:12px">
            {% for table in domain.tables %}
            <a href="{{ basePath }}load/{{ domain.normalizedName }}/{{ table.name }}.html" class="tag" style="text-decoration:none;margin-bottom:4px">{{ table.name }}</a>
            {% endfor %}
          </div>
          <div class="item-meta" style="margin-top:8px">{{ domain.tables | length }} table(s)</div>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% if jobs %}
    <div class="section">
      <h2>Transform</h2>
      <div class="item-grid">
        {% for job in jobs %}
        <div class="item-card">
          <h3>{{ job.name }}</h3>
          <p>{{ job.comment }}</p>
          <div style="margin-top:12px">
            {% for task in job.tasks %}
            <a href="{{ basePath }}transform/{{ job.normalizedName }}/{{ task.name }}.html" class="tag" style="text-decoration:none;margin-bottom:4px">{{ task.name }}</a>
            {% endfor %}
          </div>
          <div class="item-meta" style="margin-top:8px">{{ job.tasks | length }} task(s)</div>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}
  </main>
</body>
</html>
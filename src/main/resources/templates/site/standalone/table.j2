<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ pageTitle }} - Data Catalog</title>
  <link rel="stylesheet" href="{{ basePath }}style.css">
  {% if relationsJson or aclJson %}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@xyflow/react@12.6.0/dist/style.min.css">
  <script type="importmap">
  {
    "imports": {
      "react": "https://esm.sh/react@18.3.1",
      "react/": "https://esm.sh/react@18.3.1/",
      "react-dom": "https://esm.sh/react-dom@18.3.1?external=react",
      "react-dom/client": "https://esm.sh/react-dom@18.3.1/client?external=react",
      "@xyflow/react": "https://esm.sh/@xyflow/react@12.6.0?external=react,react-dom",
      "dagre": "https://esm.sh/dagre@0.8.5"
    }
  }
  </script>
  {% endif %}
</head>
<body>
  <nav class="sidebar">
    <div class="sidebar-header">
      <a href="{{ basePath }}index.html"><h2>Data Catalog</h2></a>
    </div>
    {% if domains %}
    <div class="nav-section">
      <div class="nav-section-title">Load</div>
      <ul class="nav-list">
        {% for d in domains %}
        <li>
          <details{% if d.name == domain.name %} open{% endif %}>
            <summary>{{ d.name }}</summary>
            <ul>
              {% for t in d.tables %}
              <li><a href="{{ basePath }}load/{{ d.normalizedName }}/{{ t.name }}.html"{% if t.name == table.finalName and d.name == domain.name %} style="color:var(--primary);font-weight:600"{% endif %}>{{ t.name }}</a></li>
              {% endfor %}
            </ul>
          </details>
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
    {% if jobs %}
    <div class="nav-section">
      <div class="nav-section-title">Transform</div>
      <ul class="nav-list">
        {% for j in jobs %}
        <li>
          <details>
            <summary>{{ j.name }}</summary>
            <ul>
              {% for t in j.tasks %}
              <li><a href="{{ basePath }}transform/{{ j.normalizedName }}/{{ t.name }}.html">{{ t.name }}</a></li>
              {% endfor %}
            </ul>
          </details>
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </nav>

  <main class="content">
    <div class="breadcrumb">
      <a href="{{ basePath }}index.html">Home</a> &rsaquo;
      <span>Load</span> &rsaquo;
      <span>{{ domain.name }}</span> &rsaquo;
      <span>{{ table.finalName }}</span>
    </div>

    <h1>{{ table.finalName }}</h1>
    <p class="description">{{ table.comment }}</p>

    <div class="tab-group">
      <div class="tab-bar">
        <button class="tab-btn active" data-tab="general">General</button>
        <button class="tab-btn" data-tab="attributes">Attributes</button>
        {% if table.expectations %}<button class="tab-btn" data-tab="expectations">Expectations</button>{% endif %}
        <button class="tab-btn" data-tab="relations">Relations</button>
        <button class="tab-btn" data-tab="acl">Access Control</button>
      </div>

      <div id="general" class="tab-pane active">
        <table class="data-table props-table">
          <tbody>
            <tr><th>Name</th><td>{{ table.name }}</td></tr>
            <tr><th>Pattern</th><td>{{ table.pattern }}{% if table.patternSample %} ({{ table.patternSample }}){% endif %}</td></tr>
            <tr>
              <th>Tags</th>
              <td>
                {% for tag in table.tags %}<span class="tag">{{ tag }}</span>{% endfor %}
                {% if not table.tags %}<span class="empty">None</span>{% endif %}
              </td>
            </tr>
            <tr>
              <th>Primary Key</th>
              <td>
                {% if table.primaryKey %}{{ table.primaryKey | join(', ') }}{% else %}<span class="empty">None</span>{% endif %}
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <div id="attributes" class="tab-pane">
        {% if table.attributes %}
        <div style="overflow-x:auto">
          <table class="data-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Rename</th>
                <th>Type</th>
                <th>Description</th>
                <th>Reference</th>
                <th>Required</th>
                <th>Default</th>
                <th>Tags</th>
                <th>Script</th>
                <th>Position</th>
                <th>Metric</th>
              </tr>
            </thead>
            <tbody>
              {% for attr in table.attributes %}
              <tr>
                <td><strong>{{ attr.name }}</strong></td>
                <td>{{ attr.rename }}</td>
                <td><code>{{ attr.type }}</code></td>
                <td>{{ attr.comment }}</td>
                <td>{{ attr.foreignKey }}</td>
                <td>{{ attr.required }}</td>
                <td>{{ attr.default }}</td>
                <td>{% for tag in attr.tags %}<span class="tag">{{ tag }}</span>{% endfor %}</td>
                <td>{% if attr.script %}<code>{{ attr.script }}</code>{% endif %}</td>
                <td>{{ attr.position }}</td>
                <td>{{ attr.metricType }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {% else %}
        <p class="empty">No attributes defined.</p>
        {% endif %}
      </div>

      {% if table.expectations %}
      <div id="expectations" class="tab-pane">
        <div style="overflow-x:auto">
          <table class="data-table">
            <thead>
              <tr>
                <th>Expectation</th>
                <th>Fail on Error</th>
              </tr>
            </thead>
            <tbody>
              {% for exp in table.expectations %}
              <tr>
                <td><code>{{ exp.query }}</code></td>
                <td>{{ exp.failOnError }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
      {% endif %}

      <div id="relations" class="tab-pane">
        {% if relationsJson %}
        <div id="relations-root"></div>
        <script id="relations-data" type="application/json">{{ relationsJson }}</script>
        {% else %}
        <p class="empty">No relations data available.</p>
        {% endif %}
      </div>

      <div id="acl" class="tab-pane">
        {% if aclJson %}
        <div id="acl-root"></div>
        <script id="acl-data" type="application/json">{{ aclJson }}</script>
        {% else %}
        <p class="empty">No access control data available.</p>
        {% endif %}
      </div>
    </div>
  </main>

  <script>
  document.querySelectorAll('.tab-btn').forEach(function(btn){
    btn.addEventListener('click',function(){
      var group=this.closest('.tab-group');
      group.querySelectorAll('.tab-btn').forEach(function(b){b.classList.remove('active')});
      group.querySelectorAll('.tab-pane').forEach(function(p){p.classList.remove('active')});
      this.classList.add('active');
      group.querySelector('#'+this.dataset.tab).classList.add('active');
      try{localStorage.setItem('sl-active-tab',this.dataset.tab)}catch(e){}
    });
  });
  /* Restore last active tab */
  try{
    var saved=localStorage.getItem('sl-active-tab');
    if(saved){var btn=document.querySelector('.tab-btn[data-tab="'+saved+'"]');if(btn)btn.click();}
  }catch(e){}
  </script>

  {% if relationsJson or aclJson %}
  <script type="module">
  import { mountFlow } from '{{ basePath }}flow.js';
  function lazyMount(tabName, rootId, dataId, format) {
    var data = JSON.parse(document.getElementById(dataId).textContent);
    var root = document.getElementById(rootId);
    var mounted = false;
    function doMount() { if (!mounted) { mounted = true; setTimeout(function() { mountFlow(root, data, format, 'LR'); }, 0); } }
    document.querySelector('[data-tab="'+tabName+'"]').addEventListener('click', doMount);
    if (document.querySelector('.tab-btn[data-tab="'+tabName+'"]').classList.contains('active')) doMount();
  }
  {% if relationsJson %}lazyMount('relations', 'relations-root', 'relations-data', 'table-deps');{% endif %}
  {% if aclJson %}lazyMount('acl', 'acl-root', 'acl-data', 'table-deps');{% endif %}
  </script>
  {% endif %}
</body>
</html>